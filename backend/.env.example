NODE_ENV=development
PORT=3000
MONGO_DB_URL=mongodb://localhost:27017/aura_lips
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# URL frontend (link trong email quên mật khẩu)
FRONTEND_URL=http://localhost:5173

# --- Gửi email (Gmail) ---
# 1. Bật xác minh 2 bước: https://myaccount.google.com/security
# 2. Tạo Mật khẩu ứng dụng: https://myaccount.google.com/apppasswords
# 3. Dán App Password vào SMTP_PASS (16 ký tự, không có dấu cách)

SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Aura Lips <your-email@gmail.com>"

# Hoặc SMTP tùy chỉnh (bỏ SMTP_SERVICE, dùng các dòng dưới):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
